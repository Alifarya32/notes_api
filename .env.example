# Database
DATABASE_URL="postgresql://user:pass@host/db?sslmode=require"

# JWT — WAJIB: string acak panjang (min. 32 karakter)
JWT_SECRET="ganti-dengan-secret-acak-panjang"
JWT_REFRESH_SECRET="ganti-dengan-secret-refresh-berbeda"
JWT_ACCESS_EXPIRES="15m"
JWT_REFRESH_EXPIRES_DAYS="7"

# Google OAuth
GOOGLE_CLIENT_ID="xxxx.apps.googleusercontent.com"

# CORS — domain yang diizinkan (pisahkan koma)
ALLOWED_ORIGINS="https://notesa-api.vercel.app,http://localhost:3000,http://127.0.0.1:5500"

# AI & Cloudinary
GEMINI_API_KEY=""
CLOUDINARY_CLOUD_NAME=""
CLOUDINARY_API_KEY=""
CLOUDINARY_API_SECRET=""
